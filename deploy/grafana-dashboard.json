  "annotations": {
    "list": []
  },
  "description": "OptimalEngine runtime metrics — RAG throughput, latency, memory store, BEAM health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
