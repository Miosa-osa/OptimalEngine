# ─────────────────────────────────────────────────────────────────────────────
# OptimalEngine — environment variable reference
#
# Copy this file to .env (dev) or .env.prod (production) and fill in the
# values. Never commit either of those files.
#
# docker-compose.yml reads variables from the *shell environment* and the
# optional .env file in the same directory. docker-compose.prod.yml reads
# from .env.prod via `env_file:`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Engine ───────────────────────────────────────────────────────────────────

# Port the engine HTTP API listens on inside the container (also the host
# port exposed in the dev compose file).
# Default: 4200
OPTIMAL_API_PORT=4200

# Set to "true" to require authentication on all API calls.
# PRODUCTION MUST SET THIS TO "true".
# Default: false
OPTIMAL_AUTH_REQUIRED=false

# Filesystem path inside the container where the engine reads/writes data.
# Mapped from the `optimal_data` named volume.
# Default: /data
OPTIMAL_DATA_DIR=/data

# Ollama base URL for embedding and generation requests.
# `host.docker.internal` resolves to the host machine from inside a container
# on Docker Desktop (Mac/Windows). On Linux use the host's LAN IP or run
# Ollama as a compose service.
# Default: http://host.docker.internal:11434
OPTIMAL_OLLAMA_URL=http://host.docker.internal:11434

# ── Frontend ports (dev compose only) ────────────────────────────────────────

# Host port for the desktop UI
# Default: 1420
DESKTOP_PORT=1420

# Host port for the marketing site
# Default: 1421
SITE_PORT=1421

# Host port for the docs site
# Default: 1422
DOCS_PORT=1422

# ── Production TLS (required for docker-compose.prod.yml) ────────────────────

# Your fully-qualified domain name. Caddy will request a Let's Encrypt
# certificate for this domain and its www./docs. subdomains automatically.
# Ensure DNS A records point at this server BEFORE first run.
# DOMAIN=optimal.example.com

# Email address registered with Let's Encrypt for certificate expiry notices.
# LETSENCRYPT_EMAIL=admin@example.com
