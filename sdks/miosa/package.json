{
  "name": "@miosa/optimal-engine",
  "version": "0.2.0",
  "description": "Svelte components + hooks for embedding Optimal Engine in BusinessOS modules",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hooks": {
      "svelte": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./components": {
      "svelte": "./dist/components/index.js",
      "import": "./dist/components/index.js"
    },
    "./styles/notion.css": "./dist/styles/notion.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "svelte-package -i src",
    "dev": "svelte-package -i src --watch",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@optimal-engine/client": "^0.2.0"
  },
  "devDependencies": {
    "svelte": "^5.55.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "@optimal-engine/client": "file:../typescript"
  }
}
